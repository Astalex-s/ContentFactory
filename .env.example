# ContentFactory — Environment Variables
# cp .env.example .env && edit .env

# ─── PostgreSQL ───────────────────────────────────────────
POSTGRES_USER=contentfactory
POSTGRES_PASSWORD=
POSTGRES_DB=contentfactory

# ─── Backend ──────────────────────────────────────────────
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
LOG_LEVEL=INFO

# ─── Frontend (build-time) ────────────────────────────────
# /api = proxy через nginx (Docker); http://localhost:8000 = прямой backend
VITE_API_BASE_URL=/api

# ─── PGAdmin (только dev) ────────────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=

# ─── AI (OpenAI) ─────────────────────────────────────────
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AI_TIMEOUT=60
CONTENT_GENERATE_RATE_LIMIT=10/minute

# ─── Replicate (image/video generation) ──────────────────
REPLICATE_API_TOKEN=
IMAGE_PROVIDER=replicate
REPLICATE_DELAY_SECONDS=15
REPLICATE_IMAGE_MODEL=black-forest-labs/flux-kontext-pro
REPLICATE_VIDEO_MODEL=wan-video/wan-2.2-i2v-fast
REPLICATE_VIDEO_DURATION=6

# ─── Media Storage ───────────────────────────────────────
# local = локальная FS (dev), s3 = S3-совместимое хранилище (prod)
STORAGE_BACKEND=local
MEDIA_BASE_PATH=./media
# S3 (при STORAGE_BACKEND=s3):
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_BUCKET=
# S3_REGION=us-east-1
# S3_ENDPOINT_URL=   # host или https://host (для Beget: s3.ru1.storage.beget.cloud)
# S3_PUBLIC_URL=
# S3_PRESIGNED_EXPIRE=3600

# ─── OAuth & Social ──────────────────────────────────────
# python -c "import secrets; print(secrets.token_urlsafe(32))"
OAUTH_SECRET_KEY=
# python -c "import secrets; print(secrets.token_urlsafe(16))"
OAUTH_ENCRYPTION_SALT=
DEFAULT_USER_ID=00000000-0000-0000-0000-000000000001
# OAuth-приложения (client_id, client_secret) хранятся в БД (зашифрованы)
# Продакшен: API_BASE_URL=https://your-domain.com/api (с /api — callback попадёт в backend через nginx)
API_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# ─── VK video upload (community token) ───────────────────
VK_SERVICE_KEY=
VK_GROUP_ID=
VK_COMMUNITY_TOKEN=
