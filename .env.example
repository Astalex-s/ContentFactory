# ContentFactory — Docker Compose
# cp .env.example .env && edit .env

POSTGRES_USER=contentfactory
POSTGRES_PASSWORD=
POSTGRES_DB=contentfactory

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
LOG_LEVEL=INFO
# /api = proxy через nginx (Docker) или Vite (dev); http://localhost:8000 = прямой backend
VITE_API_BASE_URL=/api

PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini-2025-08-07
AI_TIMEOUT=60
CONTENT_GENERATE_RATE_LIMIT=10/minute

REPLICATE_API_TOKEN=
IMAGE_PROVIDER=replicate
REPLICATE_DELAY_SECONDS=15
# Full version required; without it Replicate returns 404
REPLICATE_IMAGE_MODEL=stability-ai/stable-diffusion-img2img:15a3689ee13b0d2616e98820eca31d4c3abcd36672df6afce5cb6feb1d66087d
# Kling: 10–20 сек, реалистичные люди и действия. SVD: ~4 сек, только поворот камеры
# Wan 2.2 I2V Fast (дешёвый) или Veo/Kling
REPLICATE_VIDEO_MODEL=wan-video/wan-2.2-i2v-fast
REPLICATE_VIDEO_DURATION=6

SD_API_URL=http://localhost:7860
SD_DEFAULT_WIDTH=768
SD_DEFAULT_HEIGHT=768
SD_STEPS=20

# OAuth & Social (Этап 4)
# Сгенерировать: python -c "import secrets; print(secrets.token_urlsafe(32))"
OAUTH_SECRET_KEY=
# Сгенерировать: python -c "import secrets; print(secrets.token_urlsafe(16))"
OAUTH_ENCRYPTION_SALT=
# Для MVP: один тестовый пользователь (UUID)
DEFAULT_USER_ID=00000000-0000-0000-0000-000000000001
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
VK_CLIENT_ID=
VK_CLIENT_SECRET=
VK_SERVICE_KEY=
# Для загрузки видео: создать сообщество VK → Управление → Работа с API → Создать ключ (видео)
VK_GROUP_ID=
VK_COMMUNITY_TOKEN=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
API_BASE_URL=https://localhost
FRONTEND_URL=http://localhost:5173
