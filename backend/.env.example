# App
APP_NAME=ContentFactory
DEBUG=false
ENVIRONMENT=development

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Logging
LOG_LEVEL=INFO

# Database (PostgreSQL async)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/contentfactory

# AI (OpenAI) — товары, промпты для изображений
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini-2025-08-07
AI_TIMEOUT=60

# Replicate — генерация изображений товаров (SDXL)
REPLICATE_API_TOKEN=
IMAGE_PROVIDER=replicate

# Rate limit for content generation
CONTENT_GENERATE_RATE_LIMIT=10/minute
