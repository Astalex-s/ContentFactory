# ContentFactory — Production (любой домен)
# cp .env.production.example .env && edit .env
# Локальная разработка: используйте .env.example (localhost)
#
# Домен подтягивается из APP_DOMAIN (или задаёте API_BASE_URL, FRONTEND_URL, CORS_ORIGINS вручную).
# При деплое через GitHub Actions можно передать APP_DOMAIN в Secrets — он перезапишет эти значения.

# ─── Домен (опционально: задайте один APP_DOMAIN — остальное выведется автоматически) ───
# APP_DOMAIN=your-domain.com
# Или задайте вручную:
# API_BASE_URL=https://your-domain.com/api
# FRONTEND_URL=https://your-domain.com
# CORS_ORIGINS=https://your-domain.com

# ─── PostgreSQL ───────────────────────────────────────────
POSTGRES_USER=contentfactory
POSTGRES_PASSWORD=
POSTGRES_DB=contentfactory

# ─── Backend ──────────────────────────────────────────────
ENVIRONMENT=production
# Заполните вручную или задайте APP_DOMAIN — при деплое подставится из Secret
CORS_ORIGINS=https://your-domain.com
LOG_LEVEL=WARNING

# ─── Frontend (build-time) ────────────────────────────────
# /api — относительный путь, работает с любым доменом
VITE_API_BASE_URL=/api

# ─── OAuth & Social (из APP_DOMAIN или вручную) ────────────
API_BASE_URL=https://your-domain.com/api
FRONTEND_URL=https://your-domain.com

# python -c "import secrets; print(secrets.token_urlsafe(32))"
OAUTH_SECRET_KEY=
# python -c "import secrets; print(secrets.token_urlsafe(16))"
OAUTH_ENCRYPTION_SALT=
DEFAULT_USER_ID=00000000-0000-0000-0000-000000000001

# ─── AI, Replicate, Storage ───────────────────────────────
# (заполните как в .env.example)

# ─── Cron: авто-публикация и планирование ───────────────────
# На сервере cron вызывает каждую минуту:
#   curl -X POST http://127.0.0.1:8000/publish/auto-publish-check
#   curl -X POST http://127.0.0.1:8000/publish/process-pending

# (localhost — контейнер backend на том же хосте)
